    {
      "parameters": {
        "promptType": "define",
        "text": "=Draft a professional, context-aware reply to this email.\n\nFrom: {{ $json.senderName }} <{{ $json.senderEmail }}>\nSubject: {{ $json.subject }}\nCategory: {{ $json.category }}\nSummary: {{ $json.summary }}\n\nWrite a brief, professional response that acknowledges the email and indicates we will follow up soon. Keep it under 100 words.",
        "options": {
          "systemMessage": "You are a professional email assistant. Draft polite, concise replies that acknowledge receipt and indicate follow-up."
        }
      },
      "id": "73c8fafa-2e6f-430a-9ad8-610a706b408b",
      "name": "Generate Draft Reply",
