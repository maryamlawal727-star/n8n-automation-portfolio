    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze this email and categorize it.\n\nFrom: {{ $json.from.text }}\nSubject: {{ $json.subject }}\nDate: {{ $json.date }}\n\nAssign:\n1. category: Must be one of: \"Urgent Client\", \"Invoice or Payment\", \"Partnership or Opportunity\", \"Cold Outreach\", \"Newsletter or Marketing\", \"Internal Team\", \"Other\"\n2. priority: Must be one of: \"High\", \"Medium\", \"Low\"\n3. summary: One sentence describing what the email is about and what action is needed",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are an email triage assistant. Categorize emails accurately based on their content. Always return valid JSON with category, priority, and summary fields.",
          "maxIterations": 3
        }
      },
      "id": "14b77ffe-b2b7-4a77-b578-07074ccc5de0",
      "name": "Categorize Email",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        688,
        608
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "model": "llama3-70b-8192",
        "options": {
          "maxTokensToSample": 1000,
          "temperature": 0.1
        }
      },
      "id": "dbad88ef-3659-48cd-ba9e-f80286d6e97f",
      "name": "Groq Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
