    {
      "parameters": {
        "aggregate": "aggregateAllItemData",
        "destinationFieldName": "emails",
        "include": "specifiedFields",
        "fieldsToInclude": "emailId, subject, senderName, senderEmail, category, priority, summary, date",
        "options": {}
      },
      "id": "1c3e8d71-9e86-4fbe-bb27-5f18cecc5e86",
      "name": "Aggregate All Emails",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [
        1488,
        608
      ]
    },
    {
      "parameters": {
        "jsCode": "const emails = $input.first().json.emails || [];\n\n// Count by category\nconst categoryCounts = {};\nemails.forEach(email => {\n  categoryCounts[email.category] = (categoryCounts[email.category] || 0) + 1;\n});\n\n// Filter high priority emails needing attention\nconst actionItems = emails.filter(e => \n  e.priority === 'High' || \n  e.category === 'Urgent Client' || \n  e.category === 'Invoice or Payment'\n);\n\n// Format digest\nlet digest = `📧 Your Inbox Briefing – ${new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}\n\n`;\ndigest += `📊 SUMMARY\n`;\ndigest += `Total emails received: ${emails.length}\n\n`;\n\ndigest += `📁 BREAKDOWN BY CATEGORY\n`;\nObject.entries(categoryCounts).forEach(([category, count]) => {\n  digest += `• ${category}: ${count}\n`;\n});\n\ndigest += `\n⚡ PRIORITY ACTION ITEMS (${actionItems.length})\n`;\nif (actionItems.length === 0) {\n  digest += `No urgent items requiring immediate attention.\n`;\n} else {\n  actionItems.forEach((email, idx) => {\n    digest += `\n${idx + 1}. [${email.priority}] ${email.subject}\n`;\n    digest += `   From: ${email.senderName} <${email.senderEmail}>\n`;\n    digest += `   Category: ${email.category}\n`;\n    digest += `   Summary: ${email.summary}\n`;\n  });\n}\n\ndigest += `\n\n📋 ALL EMAILS\n`;\nemails.forEach((email, idx) => {\n  digest += `\n${idx + 1}. [${email.priority}] ${email.subject}\n`;\n  digest += `   From: ${email.senderName}\n`;\n  digest += `   Category: ${email.category}\n`;\n  digest += `   Summary: ${email.summary}\n`;\n});\n\nreturn [{ json: { digest, totalEmails: emails.length, actionItemsCount: actionItems.length, emails } }];"
      },
      "id": "73c3c15a-2b39-440f-8736-27c64e73a4a4",
