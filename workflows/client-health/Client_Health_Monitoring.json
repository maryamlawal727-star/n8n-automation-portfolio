        "promptType": "define",
        "text": "=Analyze this client health data and provide a health score:\n\nClient: {{ $('Pull Client Data').item.json['Client Name'] }}\nLast Invoice: {{ $('Pull Client Data').item.json['Last Invoice Date'] }}\nLast Email Reply: {{ $('Pull Client Data').item.json['Last Email Reply Date'] }}\nLast Meeting:{{ $('Pull Client Data').item.json['Last Meeting Date'] }}\nOpen Support Tickets: {{ $('Pull Client Data').item.json['Open Support Tickets'] }}\n\nProvide:\n1. A health score from 1-10 (1=Critical, 10=Excellent)\n2. A one-sentence reason for the score\n3. A status label: \"Healthy\" (8-10), \"At Risk\" (4-7), or \"Critical\" (1-3)",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a client success analyst. Evaluate client health based on engagement metrics. Consider recency of contact, invoice activity, and support needs. Be concise and actionable."
