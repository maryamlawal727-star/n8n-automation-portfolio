      "id": "37ed529d-9a75-49bd-a70d-0816c84c578b",
      "name": "Aggregate At-Risk Clients",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [
        2736,
        560
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const clients = $input.item.json.clientName;\nconst scores = $input.item.json.healthScore;\n\nlet message = \"🚨 *Client Health Alert*\\n\\n\";\nmessage += `${clients.length} at-risk client(s) detected:\n\n`;\n\nfor (let i = 0; i < clients.length; i++) {\n  message += `• ${clients[i]} - Score: ${scores[i]}/10\n`;\n}\n\nmessage += \"\\nRe-engagement drafts saved to Google Drive.\";\n\nreturn { message };"
      },
